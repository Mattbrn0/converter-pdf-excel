# --- Fournisseur LLM (choisir un seul) ---
# openai (défaut) | groq | ollama

LLM_PROVIDER=openai

# --- OpenAI (si LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Groq — tier gratuit généreux (si LLM_PROVIDER=groq) ---
# Clé gratuite : https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-70b-versatile

# --- Ollama — 100 % local, sans quota (si LLM_PROVIDER=ollama) ---
# Installer : https://ollama.com puis "ollama pull llama3.2"
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Serveur ---
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# --- Déploiement auto (webhook GitHub) ---
# Même valeur que le "Secret" dans GitHub → Settings → Webhooks
# DEPLOY_SECRET=une_cle_longue_et_secrete

# --- Supabase (optionnel) ---
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
